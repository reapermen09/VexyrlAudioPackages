{
    "blockEnd": ")",
    "blockStart": "(",
    "builtins": [
    ],
    "caseInsensitive": true,
    "constants": [
    ],
    "directives": [
    ],
    "keywords": [
        "tempo",
        "volume",
        "reverb",
        "rest",
        "pitch",
        "play",
        "startpos",
        "section",
        "override",
        "midi"
    ],
    "lineComments": [
        "//",
        "#"
    ],
    "name": "VxLanguage",
    "numbers": true,
    "operators": [
        "\\+",
        "\\-",
        "=",
        ":",
        "\\^",
        ",",
        "\\*"
    ],
    "patterns": [
        {
            "name": "custom_id",
            "regex": "\\b(?!(?:tempo|volume|rest|pitch|play|startpos|section|override|midi)\\b)[A-Za-z_][A-Za-z0-9_]*\\b",
            "style": "note"
        },
        {
            "name": "parameter",
            "regex": "\\.(beats|length|len|del|delay|start|vel|velocity|volume|vol|att|attack|rel|release|rev|reverb|revtype|pitch|pit|cents|bend|pan|vlow|low|mid|high|vhigh)\\b",
            "style": "parameter"
        },
        {
            "name": "note_token",
            "regex": "\\b[A-G][#b]?[0-9]\\b|\\.[A-Za-z_][A-Za-z0-9_]*\\b",
            "style": "note"
        },
        {
            "name": "bracket_curly",
            "regex": "[\\{\\}]",
            "style": "bracket_curly"
        },
        {
            "name": "bracket_paren",
            "regex": "[\\(\\)]",
            "style": "bracket_paren"
        },
        {
            "name": "bracket_square",
            "regex": "[\\[\\]]",
            "style": "bracket_square"
        },
        {
            "name": "bracket_angle",
            "regex": "[<>]",
            "style": "bracket_square"
        },
        {
            "groups": {
                "1": "namespace",
                "2": "instrument"
            },
            "name": "instrument_block",
            "regex": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*<\\s*([A-Za-z0-9_]+)\\s*>"
        }
    ],
    "rules": {
        "highlightBlocks": true,
        "highlightBrackets": true,
        "highlightInstruments": true,
        "highlightNotes": true,
        "highlightParameters": true
    },
    "stringDelimiters": [
    ],
    "styles": {
        "bracket_curly": "#DDDDDD",
        "bracket_paren": "#AEAEAE",
        "bracket_square": "#808080",
        "comment": "#05A005",
        "default": "#D4D4D4",
        "instrument": "#00FF7F",
        "keyword": "#6495ED",
        "namespace": "#87CEFA",
        "note": "#DDA0DD",
        "number": "#FF8C00",
        "operator": "#FFFF00",
        "parameter": "#D2691E",
        "punctuation": "#A0A0A0"
    },
    "types": [
    ]
}
