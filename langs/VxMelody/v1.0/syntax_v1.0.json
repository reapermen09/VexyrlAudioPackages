{
  "name": "VxMelody",
  "caseInsensitive": true,
  "numbers": true,

  "keywords": [
    "tempo", "delay", "length", "volume",
    "rest", "startpos",
    "instrument", "inst",
    "override", "ovr",
    "midi"
  ],

  "lineComments": ["//", "#"],

  "operators": ["\\+", "\\-", "=", ":"],

  "styles": {
    "comment": "#6272A4",
    "keyword": "#FF79C6",
    "instrument": "#50FA7B",
    "note": "#F1FA8C",
    "number": "#BD93F9",
    "operator": "#FFB86C",
    "namespace": "#8BE9FD",
    "default": "#F8F8F2"
  },

  "patterns": [
    {
      "regex": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(<)\\s*([A-Za-z0-9_]+)\\s*(>)",
      "groups": {
        "1": "namespace",
        "2": "operator",
        "3": "instrument",
        "4": "operator"
      }
    },

    {
      "regex": "\\b[A-G][#b]?[0-9]\\b|\\.[A-Za-z_][A-Za-z0-9_]*\\b",
      "style": "note"
    },

    {
      "regex": "\\b(?!(?:tempo|delay|length|volume|rest|startpos|instrument|inst|override|ovr|midi)\\b)[A-Za-z_][A-Za-z0-9_]*\\b",
      "style": "note"
    }
  ]
}
